{
  "manifest_version": 3,
  "name": "NAVI",
  "version": "1.0",
  "description": "AI-powered accessibility assistant for Google Sheets, built for BVI users.",

  "permissions": [
    "activeTab",
    "scripting",
    "identity"
  ],

  "oauth2": {
    "client_id": "923523142478-3f0r12g1ki8kkeoa56h7kdc88536gude.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/spreadsheets"
    ]
  },

  "host_permissions": [
    "https://docs.google.com/spreadsheets/*",
    "https://sheets.googleapis.com/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["https://docs.google.com/spreadsheets/*"],
      "js": ["config.js", "api.js", "content.js"],
      "css": ["styles.css"],
      "run_at": "document_end"
    }
  ],

  "web_accessible_resources": [
    {
      "resources": ["icons/*"],
      "matches": ["<all_urls>"]
    }
  ]
}